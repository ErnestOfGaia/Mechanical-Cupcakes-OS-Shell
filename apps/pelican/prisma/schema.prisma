generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
} 

// ── Recipe library ────────────────────────────────────────────────────────────

model Scrapbook {
  id         String   @id @default(uuid())
  image_url  String
  raw_text   String
  category   String   // "Technical" | "Marketing"
  recipe_id  String?
  createdAt  DateTime @default(now())
}

model MasterRecipes {
  id              String   @id @default(uuid())
  title           String
  ingredients     Json
  prep_steps      Json
  cook_steps      Json
  technical_specs String?
  marketing_lore  String?
  allergens       Json
  condiments      Json
  status          String   @default("draft")  // "draft" | "published" | "archived"
  metrics         Metric[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Training metrics ──────────────────────────────────────────────────────────

model Metric {
  id             String        @id @default(uuid())
  recipe_id      String
  recipe         MasterRecipes @relation(fields: [recipe_id], references: [id])
  quiz_score     Int
  failure_points Json
  role           String        // "prep" | "cook" | "server"
  language       String        // "English" | "Spanish" | "Russian"
  createdAt      DateTime      @default(now())
}

// ── Anonymous session tracking (for analytics dashboard) ─────────────────────
// No personal data stored — only role and timestamps.
// "Users" on the dashboard = count of RoleSession records in a time window.

model RoleSession {
  id        String    @id @default(uuid())
  role      String    // "prep" | "cook" | "server" | "admin"
  startedAt DateTime  @default(now())
  endedAt   DateTime? // null = session still active

  @@index([role])
  @@index([startedAt])
}
