# ============================================================
#  PELLITO | DECKHAND — Environment Variable Reference
#  Copy this file to .env and fill in real values.
#  .env is git-ignored. Never commit real secrets.
# ============================================================

# --- DATABASE ---
DB_USER=pellito_admin
DB_PASSWORD=your_secure_password_here

# Used directly by Prisma.
# In Docker the host is "db" (the service name), NOT localhost.
# Local dev: change "db" to "localhost".
DATABASE_URL=postgresql://pellito_admin:your_secure_password_here@db:5432/pellito_recipes

# --- AI ENGINE (OpenRouter) ---
# Sign up at https://openrouter.ai — one key routes to Gemini, Claude, Llama, etc.
OPENROUTER_API_KEY=your_openrouter_key_here

# Model to use (optional — defaults to google/gemini-flash-1.5 if not set)
# Browse models at https://openrouter.ai/models
# Examples:
#   google/gemini-flash-1.5        (fast, multimodal, recommended)
#   anthropic/claude-3-haiku       (fast, great reasoning)
#   meta-llama/llama-3-8b-instruct (open-source, budget option)
OPENROUTER_MODEL=google/gemini-flash-1.5

# --- SESSION AUTH ---
# A long random string used to sign session cookies.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_64_char_random_hex_string_here

# --- PUBLIC APP URL ---
# The public-facing URL (used for CORS headers sent to OpenRouter).
APP_URL=https://pelican.ernestofgaia.xyz
