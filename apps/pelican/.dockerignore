# Dependencies — rebuilt inside the container
node_modules
npm-debug.log*

# Git history — not needed in image
.git
.gitignore

# Next.js build output — rebuilt inside the container
.next
out
build

# Env files — secrets must NEVER go into the image
.env
.env.local
.env.production

# Dev tools
*.tsbuildinfo
.eslintcache

# OS noise
.DS_Store
Thumbs.db

# Test / coverage
coverage
